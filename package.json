{
    "name": "chess-assistant",
    "version": "1.0.0",
    "description": "Free chess analysis assistant for Chess.com using Stockfish",
    "scripts": {
        "build": "node scripts/build.js",
        "build:prod": "NODE_ENV=production node scripts/build.js",
        "watch": "node scripts/build.js --watch",
        "clean": "node scripts/build.js --clean",
        "package": "npm run build:prod && node scripts/build.js --package",
        "lint": "eslint src/**/*.js",
        "lint:fix": "eslint src/**/*.js --fix"
    },
    "devDependencies": {
        "archiver": "^6.0.1",
        "eslint": "^8.50.0",
        "fs-extra": "^11.1.1",
        "chokidar": "^3.5.3"
    },
    "keywords": [
        "chess",
        "chess.com",
        "stockfish",
        "analysis",
        "chrome-extension"
    ],
    "author": "Your Name",
    "license": "MIT"
}
{
    "name": "chess-assistant",
    "version": "1.0.0",
    "description": "Free chess analysis assistant using Stockfish for chess.com/lichess.org",
    "scripts": {
        "build": "node scripts/build.js",
        "build:prod": "cross-env NODE_ENV=production node scripts/build.js --prod",
        "build:firefox": "node scripts/build.js --firefox",
        "build:firefox:prod": "cross-env NODE_ENV=production node scripts/build.js --firefox --prod",
        "build:chrome": "node scripts/build.js --chrome",
        "build:chrome:prod": "cross-env NODE_ENV=production node scripts/build.js --chrome --prod",
        "watch": "node scripts/build.js --watch",
        "watch:firefox": "node scripts/build.js --watch --firefox",
        "clean": "node scripts/build.js --clean",
        "package": "npm run build:prod && node scripts/build.js --package",
        "package:firefox": "npm run build:firefox:prod && node scripts/build.js --firefox --package",
        "package:chrome": "npm run build:chrome:prod && node scripts/build.js --chrome --package",
        "lint": "eslint src/**/*.js",
        "lint:fix": "eslint src/**/*.js --fix",
        "test": "echo \"No tests yet\" && exit 0"
    },
    "devDependencies": {
        "archiver": "^6.0.1",
        "chokidar": "^3.5.3",
        "eslint": "^8.50.0",
        "fs-extra": "^11.1.1",
        "cross-env": "^7.0.3"
    },
    "keywords": [
        "chess",
        "chess.com",
        "stockfish",
        "analysis",
        "chrome-extension",
        "firefox-addon",
        "webextension"
    ],
    "author": "Gnomee1337",
    "license": "MIT",
    "repository": {
        "type": "git",
        "url": "https://github.com/Gnomee1337/chess-assistant"
    },
    "bugs": {
        "url": "https://github.com/Gnomee1337/chess-assistant/issues"
    },
    "dependencies": {
        "@chess-openings/eco.json": "^1.1.0"
    }
}
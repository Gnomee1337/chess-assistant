{
  "manifest_version": 2,
  "name": "Chess Assistant [DEBUG]",
  "version": "1.0.0",
  "description": "Free chess analysis assistant using Stockfish - DEBUG BUILD",
  "permissions": [
    "storage",
    "https://www.chess.com/*",
    "tabs",
    "activeTab",
    "https://lichess.org/*",
    "https://cdn.jsdelivr.net/*"
  ],
  "content_security_policy": "script-src 'self' https://cdn.jsdelivr.net 'wasm-unsafe-eval' 'unsafe-eval'; object-src 'self'",
  "background": {
    "scripts": [
      "background.js"
    ],
    "persistent": true
  },
  "content_scripts": [
    {
      "matches": [
        "https://www.chess.com/*",
        "https://lichess.org/*"
      ],
      "js": [
        "content.js"
      ],
      "css": [
        "overlay.css"
      ],
      "run_at": "document_idle"
    }
  ],
  "web_accessible_resources": [
    "stockfish.js",
    "stockfish.wasm",
    "ecoA.json",
    "ecoB.json",
    "ecoC.json",
    "ecoD.json",
    "ecoE.json"
  ],
  "browser_action": {
    "default_popup": "popup.html",
    "default_icon": {
      "16": "icon.png",
      "48": "icon.png",
      "128": "icon.png"
    }
  },
  "icons": {
    "16": "icon.png",
    "48": "icon.png",
    "128": "icon.png"
  }
}
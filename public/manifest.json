{
  "manifest_version": 3,
  "name": "Chess Assistant",
  "version": "1.0.0",
  "description": "Free chess analysis assistant using Stockfish for chess.com/lichess.org",
  "permissions": [
    "storage",
    "offscreen"
  ],
  "host_permissions": [
    "https://www.chess.com/*",
    "https://lichess.org/*"
  ],
  "content_security_policy": {
    "extension_pages": "script-src 'self' 'wasm-unsafe-eval'; object-src 'self'"
  },
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": [
        "https://www.chess.com/*",
        "https://lichess.org/*"
      ],
      "js": [
        "browser-polyfill.js",
        "content.js"
      ],
      "css": [
        "overlay.css"
      ],
      "run_at": "document_idle"
    }
  ],
  "web_accessible_resources": [
    {
      "resources": [
        "stockfish.js",
        "stockfish.wasm",
        "ecoA.json",
        "ecoB.json",
        "ecoC.json",
        "ecoD.json",
        "ecoE.json"
      ],
      "matches": [
        "https://www.chess.com/*",
        "https://lichess.org/*"
      ]
    }
  ],
  "action": {
    "default_popup": "popup.html",
    "default_icon": {
      "16": "icon.png",
      "48": "icon.png",
      "128": "icon.png"
    }
  },
  "icons": {
    "16": "icon.png",
    "48": "icon.png",
    "128": "icon.png"
  }
}